HEYA_HTTP_ADDR=:8998

# By default, projectPath values must stay inside the parent directory of this service.
# Set this explicitly on the server.
HEYA_PROJECT_BASE_DIR=/Library/WebServer/Documents
# Optional: if set, /dev/run can be called with an empty JSON body.
HEYA_DEFAULT_PROJECT_DIR=/Library/WebServer/Documents/abc/storage/app/frontend

HEYA_DEFAULT_DEV_PORT=3002
HEYA_DEV_SERVER_SCHEME=http
HEYA_DEV_SERVER_HOST=localhost
HEYA_LOG_DIR=/tmp/heya-solidjs-manager/logs
HEYA_BUILD_ROOT_DIR=/tmp/heya-builds
HEYA_NPM_BIN=npm
HEYA_COMMAND_SHELL=/bin/zsh
HEYA_DEV_READY_TIMEOUT=60s
HEYA_DEV_IDLE_TIMEOUT=30s
HEYA_PROCESS_STOP_TIMEOUT=15s
